generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Mirrors packages/shared UserRole.
enum UserRole {
  CUSTOMER
  RESTAURANT
  DELIVERY
  DRIVER
  SUPPORT
  FINANCE
  ADMIN
  SUPER_ADMIN
}

/// Mirrors packages/shared AdminType.
enum AdminType {
  ADMIN
  SUPER_ADMIN
}

/// Mirrors packages/shared StoreType.
enum StoreType {
  FOOD
  GROCERY
  PHARMACY
}

/// Mirrors packages/shared VehicleType.
enum VehicleType {
  BIKE
  AUTO
  CAB
}

/// Mirrors packages/shared PaymentMethod.
enum PaymentMethod {
  WALLET
  CASH
  ONLINE
}

/// Mirrors packages/shared PaymentStatus.
enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

/// Mirrors packages/shared ServiceType.
enum ServiceType {
  FOOD
  GROCERY
  PHARMACY
  RIDE
  COURIER
  HOME_SERVICE
}

/// Mirrors packages/shared OrderStatus.
enum OrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  READY
  PICKED_UP
  DELIVERED
  CANCELLED
}

/// Mirrors packages/shared RideStatus.
enum RideStatus {
  REQUESTED
  ASSIGNED
  ARRIVED
  IN_RIDE
  COMPLETED
  CANCELLED
}

/// Mirrors packages/shared CourierStatus.
enum CourierStatus {
  REQUESTED
  ASSIGNED
  ARRIVED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

/// Mirrors packages/shared HomeServiceStatus.
enum HomeServiceStatus {
  REQUESTED
  ASSIGNED
  ARRIVED
  IN_SERVICE
  COMPLETED
  CANCELLED
}

enum PartnerApproval {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum LedgerEntryType {
  CREDIT
  DEBIT
  COMMISSION
  PAYOUT
  REFUND
  ADJUSTMENT
  PROMOTION
  LOYALTY
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum InvoiceType {
  ORDER
  RIDE
  COURIER
  HOME_SERVICE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

enum CouponDiscountType {
  PERCENTAGE
  FLAT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DisputeReferenceType {
  ORDER
  RIDE
  COURIER
  HOME_SERVICE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum DisputeReason {
  NOT_DELIVERED
  DAMAGED_OR_INCOMPLETE
  OVERCHARGED
  SAFETY_OR_BEHAVIOR
  CANCELLATION_FEE
  OTHER
}

enum DisputeResolution {
  REFUND
  WALLET_CREDIT
  PARTNER_CREDIT
  NO_ACTION
  OTHER
}

enum ReconciliationReportStatus {
  CLEAR
  HAS_MISMATCHES
}
enum NotificationType {
  SYSTEM
  ORDER
  RIDE
  PAYMENT
  SUPPORT
  PROMOTION
}

enum PartnerShiftStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

model User {
  id                  String          @id @default(cuid())
  role                UserRole
  adminType           AdminType?
  phoneE164           String?
  email               String?
  passwordHash        String?
  mfaEnabled          Boolean         @default(false)
  mfaSecretEncrypted  Json?
  name                String?
  avatarUrl           String?
  walletBalanceCached Decimal         @default(0) @db.Decimal(14, 2)
  referralCode        String?         @unique
  referredById        String?
  isBanned            Boolean         @default(false)
  isOnline            Boolean         @default(false)
  lastSeenAt          DateTime?
  partnerApproval     PartnerApproval @default(NONE)
  rejectionReason     String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @default(now()) @updatedAt

  addresses                       Address[]
  ownedStores                     Store[]              @relation("StoreOwner")
  customerOrders                  Order[]              @relation("OrderCustomer")
  deliveryOrders                  Order[]              @relation("OrderDeliveryPartner")
  customerRides                   Ride[]               @relation("RideCustomer")
  driverRides                     Ride[]               @relation("RideDriver")
  customerCourierBookings         CourierBooking[]     @relation("CourierCustomer")
  deliveryPartnerCourierBookings CourierBooking[]     @relation("CourierDeliveryPartner")
  customerHomeServiceBookings     HomeServiceBooking[] @relation("HomeServiceCustomer")
  professionalHomeServiceBookings HomeServiceBooking[] @relation("HomeServiceProfessional")
  ledgerEntries                   LedgerEntry[]
  favorites                       Favorite[]
  referralsMade                   Referral[]          @relation("ReferralReferrer")
  referralReceived                Referral?           @relation("ReferralReferee")
  payouts                         Payout[]
  invoices                        Invoice[]
  supportTickets                  SupportTicket[]      @relation("TicketUser")
  assignedSupportTickets          SupportTicket[]      @relation("TicketAssignee")
  customerDisputes                Dispute[]            @relation("DisputeCustomer")
  partnerDisputes                 Dispute[]            @relation("DisputePartner")
  disputeActions                  DisputeAction[]      @relation("DisputeActionActor")
  notifications                   Notification[]
  auditLogs                       AuditLog[]           @relation("AuditActor")
  sessions                        Session[]
  partnerShifts                   PartnerShift[]
  partnerOnlineSessions           PartnerOnlineSession[]
  updatedFeatureFlags             FeatureFlag[]        @relation("FeatureFlagUpdater")

  @@index([role])
  @@index([mfaEnabled, role])
  @@index([partnerApproval])
  @@index([referralCode])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  storeId    String?
  menuItemId String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  store    Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@unique([userId, menuItemId])
  @@index([userId, createdAt(sort: Desc)])
}

model Referral {
  id                 String    @id @default(cuid())
  referrerId         String
  refereeId          String    @unique
  code               String
  referrerCreditedAt DateTime?
  refereeCreditedAt  DateTime?
  createdAt          DateTime  @default(now())

  referrer User @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Restrict)
  referee  User @relation("ReferralReferee", fields: [refereeId], references: [id], onDelete: Restrict)

  @@index([referrerId, createdAt(sort: Desc)])
  @@index([code])
}


model PartnerShift {
  id        String             @id @default(cuid())
  userId    String
  startsAt  DateTime
  endsAt    DateTime
  status    PartnerShiftStatus @default(SCHEDULED)
  note      String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
  @@index([status, startsAt])
}

model PartnerOnlineSession {
  id              String    @id @default(cuid())
  userId          String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  lastHeartbeatAt DateTime?
  durationSeconds Int?
  source          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([userId, endedAt])
}
model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
}
model Address {
  id        String   @id @default(cuid())
  userId    String
  line      String
  city      String
  state     String
  pincode   String
  lat       Decimal  @db.Decimal(10, 7)
  lng       Decimal  @db.Decimal(10, 7)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Store {
  id               String          @id @default(cuid())
  ownerId          String
  type             StoreType
  name             String
  description      String
  imageUrl         String?
  licenseUrl       String?
  ratingAverage    Decimal         @default(0) @db.Decimal(3, 2)
  ratingCount      Int             @default(0)
  etaMinutes       Int
  minOrder         Decimal         @default(0) @db.Decimal(12, 2)
  deliveryRadiusKm Decimal         @default(0) @db.Decimal(6, 2)
  lat              Decimal         @db.Decimal(10, 7)
  lng              Decimal         @db.Decimal(10, 7)
  location         Unsupported("geography(Point,4326)")?
  isOpen           Boolean         @default(false)
  approval         PartnerApproval @default(PENDING)
  rejectionReason  String?
  bankAccount      Json?
  openingHours     Json            @default("{}")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @default(now()) @updatedAt

  owner     User       @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  menuItems MenuItem[]
  favorites Favorite[]
  orders    Order[]

  @@index([ownerId])
  @@index([type, approval, isOpen])
}

model MenuItem {
  id             String   @id @default(cuid())
  storeId        String
  section        String
  name           String
  description    String
  price          Decimal  @db.Decimal(12, 2)
  imageUrl       String?
  tags           String[] @default([])
  available      Boolean  @default(true)
  stock          Int      @default(-1)
  customizations Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@index([storeId, available])
}
model Order {
  id                String        @id @default(cuid())
  customerId        String
  storeId           String
  deliveryPartnerId String?
  serviceType       ServiceType
  items             Json
  status            OrderStatus   @default(PLACED)
  timeline          Json          @default("[]")
  address           Json
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  subtotal          Decimal       @db.Decimal(12, 2)
  deliveryFee       Decimal       @default(0) @db.Decimal(12, 2)
  discount          Decimal       @default(0) @db.Decimal(12, 2)
  taxes             Decimal       @default(0) @db.Decimal(12, 2)
  total             Decimal       @db.Decimal(12, 2)
  couponCode        String?
  prepTimeMinutes   Int?
  pickupOtpHash     String?
  deliveryOtpHash   String?
  storeLocation     Json
  rated             Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt

  customer        User          @relation("OrderCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  deliveryPartner User?         @relation("OrderDeliveryPartner", fields: [deliveryPartnerId], references: [id], onDelete: SetNull)
  ledgerEntries   LedgerEntry[]

  @@index([customerId, createdAt(sort: Desc)])
  @@index([storeId, status])
  @@index([deliveryPartnerId, status, createdAt(sort: Desc)])
}

model Ride {
  id                String        @id @default(cuid())
  customerId        String
  driverId          String?
  vehicleType       VehicleType
  pickup            Json
  drop              Json
  status            RideStatus    @default(REQUESTED)
  estimatedFare     Decimal       @db.Decimal(12, 2)
  finalFare         Decimal?      @db.Decimal(12, 2)
  distanceKm        Decimal?      @db.Decimal(8, 2)
  durationMinutes   Int?
  surgeMultiplier   Decimal       @default(1) @db.Decimal(5, 2)
  startOtpHash      String?
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus @default(PENDING)
  rated             Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt

  customer      User          @relation("RideCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  driver        User?         @relation("RideDriver", fields: [driverId], references: [id], onDelete: SetNull)
  ledgerEntries LedgerEntry[]

  @@index([customerId, createdAt(sort: Desc)])
  @@index([driverId, status, createdAt(sort: Desc)])
  @@index([status, vehicleType, createdAt(sort: Desc)])
}

model CourierBooking {
  id                 String        @id @default(cuid())
  customerId         String
  deliveryPartnerId  String?
  pickup             Json
  drop               Json
  status             CourierStatus @default(REQUESTED)
  packageDescription String
  packageWeightKg    Decimal?      @db.Decimal(8, 2)
  estimatedFare      Decimal       @db.Decimal(12, 2)
  finalFare          Decimal?      @db.Decimal(12, 2)
  distanceKm         Decimal?      @db.Decimal(8, 2)
  pickupOtpHash      String?
  deliveryOtpHash    String?
  paymentMethod      PaymentMethod
  paymentStatus      PaymentStatus @default(PENDING)
  rated              Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @default(now()) @updatedAt

  customer        User  @relation("CourierCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  deliveryPartner User? @relation("CourierDeliveryPartner", fields: [deliveryPartnerId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt(sort: Desc)])
  @@index([deliveryPartnerId, status, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model HomeServiceBooking {
  id                 String            @id @default(cuid())
  customerId         String
  professionalId     String?
  serviceCategory    String
  serviceDescription String
  address            Json
  scheduledFor       DateTime?
  status             HomeServiceStatus @default(REQUESTED)
  estimatedFare      Decimal           @db.Decimal(12, 2)
  finalFare          Decimal?          @db.Decimal(12, 2)
  durationMinutes    Int?
  startOtpHash       String?
  paymentMethod      PaymentMethod
  paymentStatus      PaymentStatus     @default(PENDING)
  rated              Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt

  customer     User  @relation("HomeServiceCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  professional User? @relation("HomeServiceProfessional", fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt(sort: Desc)])
  @@index([professionalId, status, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
model HomeServiceCatalogItem {
  id              String   @id @default(cuid())
  code            String   @unique
  category        String
  name            String
  description     String
  price           Decimal  @db.Decimal(12, 2)
  durationMinutes Int
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([category, isActive, sortOrder])
  @@index([isActive, sortOrder])
}
model LedgerEntry {
  id            String          @id @default(cuid())
  userId        String
  userRole      UserRole
  type          LedgerEntryType
  amount        Decimal         @db.Decimal(14, 2)
  description   String
  paymentMethod PaymentMethod?
  orderId       String?
  rideId        String?
  isSettled     Boolean         @default(false)
  paymentId     String?
  createdAt     DateTime        @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  ride  Ride?  @relation(fields: [rideId], references: [id], onDelete: SetNull)

  @@unique([paymentId])
  @@index([userId, isSettled, type])
  @@index([orderId])
  @@index([rideId])
}

model Payout {
  id                String       @id @default(cuid())
  userId            String
  userRole          UserRole
  amount            Decimal      @db.Decimal(14, 2)
  status            PayoutStatus @default(PENDING)
  bankAccountName   String
  bankAccountNumber String
  bankIfsc          String
  reference         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, status, createdAt(sort: Desc)])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique @default(dbgenerated("next_invoice_number()"))
  customerId    String
  recipient     Json
  type          InvoiceType
  referenceId   String
  amount        Decimal       @db.Decimal(14, 2)
  taxBreakdown  Json          @default("{}")
  status        InvoiceStatus @default(ISSUED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt

  customer User @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([customerId, createdAt(sort: Desc)])
  @@index([type, referenceId])
}

model Coupon {
  id            String             @id @default(cuid())
  code          String             @unique
  title         String
  description   String?
  serviceType    ServiceType?
  campaignName   String?
  campaignTag    String?
  firstOrderOnly Boolean      @default(false)
  metadata       Json?
  discountType  CouponDiscountType
  discountValue Decimal            @db.Decimal(12, 2)
  maxDiscount   Decimal?           @db.Decimal(12, 2)
  minOrderValue Decimal?           @db.Decimal(12, 2)
  startsAt      DateTime?
  expiresAt     DateTime?
  usageLimit    Int?
  usageCount    Int                @default(0)
  perUserLimit  Int?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @default(now()) @updatedAt

  @@index([serviceType, isActive])
  @@index([expiresAt])
}

model SupportTicket {
  id            String                @id @default(cuid())
  userId        String?
  assignedToId  String?
  subject       String
  message       String
  status        SupportTicketStatus   @default(OPEN)
  priority      SupportTicketPriority @default(MEDIUM)
  referenceType String?
  referenceId   String?
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @default(now()) @updatedAt

  user       User? @relation("TicketUser", fields: [userId], references: [id], onDelete: SetNull)
  assignedTo User? @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  disputes   Dispute[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([assignedToId, status])
  @@index([status, priority, createdAt(sort: Desc)])
}

model Dispute {
  id              String               @id @default(cuid())
  supportTicketId String
  customerId      String
  partnerId       String?
  referenceType   DisputeReferenceType
  referenceId     String
  reason          DisputeReason
  status          DisputeStatus        @default(OPEN)
  resolution      DisputeResolution?
  summary         String
  customerNote    String?
  partnerNote     String?
  resolvedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @default(now()) @updatedAt

  supportTicket SupportTicket   @relation(fields: [supportTicketId], references: [id], onDelete: Restrict)
  customer      User            @relation("DisputeCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  partner       User?           @relation("DisputePartner", fields: [partnerId], references: [id], onDelete: SetNull)
  actions       DisputeAction[]

  @@index([customerId, createdAt(sort: Desc)])
  @@index([partnerId, status, createdAt(sort: Desc)])
  @@index([referenceType, referenceId])
  @@index([status, createdAt(sort: Desc)])
}

model DisputeAction {
  id          String             @id @default(cuid())
  disputeId   String
  actorId     String?
  actorRole   UserRole?
  action      String
  note        String?
  statusFrom  DisputeStatus?
  statusTo    DisputeStatus?
  resolution  DisputeResolution?
  metadata    Json?
  createdAt   DateTime           @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  actor   User?   @relation("DisputeActionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([disputeId, createdAt])
  @@index([actorId, createdAt(sort: Desc)])
}

model PaymentReconciliationReport {
  id             String                     @id @default(cuid())
  provider       String                     @default("RAZORPAY")
  status         ReconciliationReportStatus
  from           DateTime
  to             DateTime
  providerTotal  Decimal                    @default(0) @db.Decimal(14, 2)
  ledgerTotal    Decimal                    @default(0) @db.Decimal(14, 2)
  mismatchCount  Int                        @default(0)
  matchedCount   Int                        @default(0)
  rows           Json
  mismatches     Json
  createdAt      DateTime                   @default(now())

  @@index([provider, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  UserRole?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([action, createdAt(sort: Desc)])
}

model AnalyticsDailyProjection {
  id                    String   @id @default(cuid())
  date                  DateTime @db.Date
  scope                 String   @default("ALL")
  ordersCount           Int      @default(0)
  ridesCount            Int      @default(0)
  courierCount          Int      @default(0)
  homeServiceCount      Int      @default(0)
  gmv                   Decimal  @default(0) @db.Decimal(14, 2)
  activePartners        Int      @default(0)
  refreshedAt           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  @@unique([date, scope])
  @@index([scope, date])
}

model FeatureFlag {
  key         String   @id
  description String?
  enabled     Boolean  @default(false)
  rollout     Json     @default("{}")
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  updatedBy User? @relation("FeatureFlagUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([enabled, updatedAt])
}
model SystemConfig {
  key         String   @id
  value       Json
  description String?
  isSecret    Boolean  @default(false)
  updatedAt   DateTime @default(now()) @updatedAt
}

model OutboxEvent {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  attempts    Int       @default(0)

  @@index([processedAt, createdAt])
  @@index([type, createdAt])
}




