NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://movex:movex@localhost:5432/movex?schema=public
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:3000

SESSION_COOKIE_NAME=__Host-movex_session
CSRF_COOKIE_NAME=movex_csrf

SMS_PROVIDER=mock
SMS_MOCK_BASE_URL=http://localhost:1080
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

AUTH_HASH_SECRET=replace-with-a-long-random-secret
SESSION_TTL_SECONDS=2592000
OTP_TTL_SECONDS=300
OTP_REQUEST_PHONE_LIMIT=3
OTP_REQUEST_IP_LIMIT=20
OTP_VERIFY_PHONE_LIMIT=20
OTP_VERIFY_IP_LIMIT=60
ADMIN_BOOTSTRAP_TOKEN=replace-with-one-time-setup-token

MAPS_PROVIDER=google
GOOGLE_MAPS_API_KEY=
MAPS_GEOCODE_CACHE_TTL_MS=300000
MAPS_ROUTE_CACHE_TTL_MS=60000

PAYMENT_PROVIDER=mock
RAZORPAY_WEBHOOK_SECRET=
PAYMENT_IDEMPOTENCY_TTL_MS=86400000
PAYMENT_WEBHOOK_PROCESSED_TTL_MS=604800000
PAYMENT_WEBHOOK_LOCK_TTL_MS=30000

EMAIL_PROVIDER=mock
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM="MoveX <notifications@example.com>"

SEARCH_PROVIDER=postgres
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=movex-dev-search-key
MEILISEARCH_STORE_INDEX=movex_stores

# Production readiness
STAFF_MFA_REQUIRED=true
CONFIG_SECRET_KEY=replace-with-32-byte-config-secret
MFA_SECRET_KEY=replace-with-32-byte-mfa-secret
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
MQTT_ENABLED=false
MQTT_BROKER_ACL_CONFIGURED=false
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
